<% layout("/layouts/boilerplate.ejs")%>
  <div class="row mt-3 justify-content-center">
    <div class="col-lg-8 col-md-10 col-12">
      <br /><br />
      <h3>Create New Listing</h3>
<form
        method="POST"
        action="/listings"
        class="premium-form needs-validation"
        novalidate
        enctype="multipart/form-data"
      >
        <div class="form-floating mb-3">
          <input
            name="listing[title]"
            id="title"
            placeholder="Title"
            type="text"
            class="form-control"
            required
          />
          <label for="title">Title</label>
          <div class="valid-feedback">Title looks good!</div>
        </div>

        <div class="form-floating mb-3">
          <textarea
            name="listing[description]"
            id="description"
            class="form-control"
            placeholder="Description"
            required
          ></textarea>
          <label for="description">Description</label>
            <div class="invalid-feedback">Please enter a short description</div>
        </div>
      
        <div class="mb-3">
          <label for="image" class="form-label">Upload Listing Image</label>
          <input
            name="listing[image]"
            type="file"
            class="form-control"
            required
          />
        </div>
        <div class="row g-3">
          <div class="col-lg-4 col-md-6 col-12 mb-3">
            <label for="price" class="form-label">Price</label>
            <input
              name="listing[price]"
              placeholder="1200"
              class="form-control"
              required
            />
            <div class="invalid-feedback">Price should be a valid number</div>
          </div>
          <div class="col-lg-8 col-md-6 col-12 mb-3">
            <label for="country" class="form-label">Country</label>
            <input
              name="listing[country]"
              placeholder="India"
              type="text"
              class="form-control"
              required
            />
            <div class="invalid-feedback">Country name should be valid</div>
          </div>
        </div>

        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input
            name="listing[location]"
            placeholder="Jaipur,Rajasthan"
            type="text"
            class="form-control"
          /><div class="invalid-feedback">Location should be valid</div>
          <br /><br />
        </div>
        <button type="submit" class="btn btn-premium mt-3">Create Wanderlust Listing</button>
        <br /><br />
      </form>
    </div>
  </div>
