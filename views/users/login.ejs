<% layout("/layouts/boilerplate.ejs")%>

<div class="row mt-3">
    <h1 class="col-6 offset-3">Login</h1>
<div class="col-6 offset-3">
    <form action="/login" method="POST" class="premium-form needs-validation" novalidate>
      <div class="form-floating mb-3">
        <input
          name="username"
          id="username"
          type="text"
          class="form-control"
          placeholder="Username"
          required
        />
        <label for="username">Username</label>
      </div>
       <div class="form-floating mb-3">
        <input
          name="password"
          id="password"
          type="password"
          class="form-control"
          placeholder="Password"
          required
        />
        <label for="password">Password</label>
      </div>
      <button type="submit" class="btn btn-premium">Login to Wanderlust</button>
    </form>
  </div>
</div>
