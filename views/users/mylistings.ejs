<% layout('/layouts/boilerplate') %>
<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Listings (<%= userListings.length %>)</h2>
    <a href="/listings/new" class="btn btn-primary">Add New Listing</a>
  </div>
  <% if(userListings.length > 0) { %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
      <% for(let listing of userListings) { %>
        <div class="col">
          <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card listing-card">
              <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>">
              <div class="card-body">
                <h5 class="card-title"><%= listing.title %></h5>
                <p class="card-text">
                  <span class="price">₹<%= listing.price.toLocaleString("en-IN") %> /night</span>
                </p>
              </div>
            </div>
          </a>
        </div>
      <% } %>
    </div>
  <% } else { %>
    <div class="text-center py-5">
      <i class="fa-solid fa-house fa-4x text-muted mb-4"></i>
      <h3 class="text-muted mb-3">No listings yet</h3>
      <p class="text-muted mb-4">Start by adding your first listing!</p>
      <a href="/listings/new" class="btn btn-primary btn-lg">Create Listing</a>
    </div>
  <% } %>
</div>

