<% layout('/layouts/boilerplate') %>
<div class="row">
  <div class="col-12 col-md-3">
    <div class="card profile-card mb-4">
      <div class="card-body text-center">
        <i class="fa-solid fa-circle-user fa-5x mb-3 text-muted"></i>
        <h2 class="card-title"><%= user.username %></h2>
        <p class="text-muted"><%= user.email %></p>
        <a href="/listings/new" class="btn btn-primary">Add Listing</a>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-9">
    <h3 class="mb-4" id="my-listings">Your Listings</h3>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
      <% if(userListings.length > 0) { %>
        <% for(let listing of userListings) { %>
          <div class="col">
            <a href="/listings/<%= listing._id %>" class="listing-link">
              <div class="card listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>">
                <div class="card-body">
                  <h5 class="card-title"><%= listing.title %></h5>
                  <p class="card-text">
                    <span class="price">₹<%= listing.price.toLocaleString("en-IN") %> /night</span>
                  </p>
                </div>
              </div>
            </a>
          </div>
        <% } %>
      <% } else { %>
        <div class="col-12">
          <div class="text-center py-5">
            <i class="fa-solid fa-house fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">No listings yet</h4>
            <p class="text-muted">Be the first to share your place on Wanderlust!</p>
            <a href="/listings/new" class="btn btn-primary btn-lg">Add Your First Listing</a>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>

<style>
.profile-card {
  border-radius: 20px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.1);
}

.profile-card .fa-circle-user {
  color: #ff385c;
}
</style>

